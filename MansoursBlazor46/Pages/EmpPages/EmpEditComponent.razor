@page "/Emps/Edit/{id:int}"
<PageTitle>Edit Employee</PageTitle>
<h3>EmpEditComponent</h3>
@if (EmployeeObj != null)
{
    <EditForm Model="EmployeeObj" OnValidSubmit="Save" OnInvalidSubmit="ShowMsg">
        <!--buiult in coponent start valiadtion-->
        <DataAnnotationsValidator></DataAnnotationsValidator>
        <ValidationSummary></ValidationSummary>
        <div>
            <label>Name</label>
            <InputText class="form form-control" @bind-Value="EmployeeObj.Name"></InputText>
            <ValidationMessage For="()=>EmployeeObj.Name"></ValidationMessage>
        </div>
        <div>
            <label>Salary</label>
            <InputNumber class="form form-control" @bind-Value="EmployeeObj.Salary"></InputNumber>
            <ValidationMessage For="()=>EmployeeObj.Salary"></ValidationMessage>

        </div>
        <div>
            <label>Department</label>
            <InputNumber class="form form-control" @bind-Value="EmployeeObj.DepartmentId"></InputNumber>
            <ValidationMessage For="()=>EmployeeObj.DepartmentId"></ValidationMessage>

        </div>
        <input type="submit" class="btn btn-primary" value="Save" />
    </EditForm>
    <h1>@EmployeeObj</h1>
}
else
{
    <h1>Wait ... or invalid id</h1>
}



